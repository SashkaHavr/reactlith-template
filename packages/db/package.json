{
  "name": "@reactlith-template/db",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "build": "tsdown ./src/migrate.ts -d ./dist",
    "db:generate": "pnpm exec drizzle-kit generate",
    "db:migrate": "node ./src/migrate.ts",
    "db:push": "pnpm exec drizzle-kit push",
    "db:studio": "pnpm exec drizzle-kit studio"
  },
  "dependencies": {
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@reactlith-template/env": "workspace:*",
    "@reactlith-template/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "better-result": "catalog:",
    "drizzle-kit": "catalog:drizzle",
    "drizzle-orm": "catalog:drizzle",
    "typescript": "catalog:",
    "uuid": "catalog:",
    "zod": "catalog:"
  }
}
