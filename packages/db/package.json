{
  "name": "@reactlith-template/db",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "build": "bun build --entrypoints ./src/migrate.ts --outdir ./dist --target bun",
    "db:generate": "bunx --no-install --bun drizzle-kit generate",
    "db:migrate": "bun run ./src/migrate.ts",
    "db:push": "bunx --no-install --bun drizzle-kit push",
    "db:studio": "bunx --no-install --bun drizzle-kit studio"
  },
  "devDependencies": {
    "@reactlith-template/env": "workspace:*",
    "@reactlith-template/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "better-result": "catalog:",
    "drizzle-kit": "catalog:drizzle",
    "drizzle-orm": "catalog:drizzle",
    "typescript": "catalog:",
    "uuid": "catalog:",
    "zod": "catalog:"
  }
}
