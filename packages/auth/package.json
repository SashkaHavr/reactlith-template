{
  "name": "@reactlith-template/auth",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts",
    "./permissions": "./src/permissions.ts"
  },
  "scripts": {
    "build": "tsdown ./src/generate-test-users.ts -d ./dist",
    "generate-db-schema": "bunx auth@latest generate --config generated/config.ts --output ./generated/auth-schema.ts --yes",
    "generate-test-users": "node ./src/generate-test-users.ts"
  },
  "devDependencies": {
    "@reactlith-template/db": "workspace:*",
    "@reactlith-template/env": "workspace:*",
    "@reactlith-template/typescript-config": "workspace:*",
    "@reactlith-template/utils": "workspace:*",
    "@types/node": "catalog:",
    "better-auth": "catalog:",
    "typescript": "catalog:"
  }
}
