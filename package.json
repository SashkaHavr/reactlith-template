{
  "name": "reactlith-template",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@t3-oss/env-core": "0.13.11",
      "@tanstack/react-form": "1.28.6",
      "@types/bun": "1.3.11",
      "better-auth": "1.5.6",
      "lucide-react": "1.7.0",
      "superjson": "2.2.6",
      "typescript": "6.0.2",
      "use-intl": "4.8.3",
      "uuid": "13.0.0",
      "zod": "4.3.6",
      "pino": "10.3.1",
      "pino-pretty": "13.1.3"
    },
    "catalogs": {
      "drizzle": {
        "drizzle-kit": "1.0.0-beta.15-859cf75",
        "drizzle-orm": "1.0.0-beta.15-859cf75"
      },
      "react": {
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "babel-plugin-react-compiler": "1.0.0"
      },
      "tailwind": {
        "@tailwindcss/vite": "4.2.2",
        "class-variance-authority": "0.7.1",
        "clsx": "2.1.1",
        "tailwind-merge": "3.5.0",
        "tailwindcss": "4.2.2",
        "tw-animate-css": "1.4.0"
      },
      "trpc": {
        "@tanstack/react-query": "5.94.5",
        "@trpc/client": "11.16.0",
        "@trpc/server": "11.16.0",
        "@trpc/tanstack-react-query": "11.16.0"
      },
      "vite": {
        "@tanstack/react-router": "1.168.8",
        "@tanstack/react-router-ssr-query": "1.166.10",
        "@tanstack/react-start": "1.167.13",
        "@tanstack/router-plugin": "1.167.9",
        "@vitejs/plugin-react": "6.0.1",
        "@types/babel__core": "7.20.5",
        "vite": "8.0.3",
        "@rolldown/plugin-babel": "0.2.2",
        "nitro": "3.0.260311-beta"
      }
    }
  },
  "scripts": {
    "build": "bun run --filter '*' build",
    "clean": "git clean -xdfq 'node_modules/*' '**/node_modules/*' '**/dist/*'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check": "oxlint && oxfmt --check",
    "fix": "oxlint --fix && oxfmt",
    "compose": "docker compose -f docker-compose.yaml -f docker-compose.dev.yaml up --build -d",
    "deps": "bun update --interactive --recursive"
  },
  "devDependencies": {
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.18.1"
  },
  "packageManager": "bun@1.3.11"
}
