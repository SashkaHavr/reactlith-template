{
  "name": "reactlith-template",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@t3-oss/env-core": "0.13.11",
      "@tanstack/react-form": "1.29.1",
      "@types/bun": "1.3.12",
      "better-auth": "1.6.5",
      "better-result": "2.8.2",
      "lucide-react": "1.8.0",
      "superjson": "2.2.6",
      "typescript": "6.0.3",
      "use-intl": "4.9.1",
      "uuid": "14.0.0",
      "zod": "4.3.6",
      "evlog": "2.13.0"
    },
    "catalogs": {
      "drizzle": {
        "drizzle-kit": "1.0.0-beta.20",
        "drizzle-orm": "1.0.0-beta.20",
        "drizzle-seed": "1.0.0-beta.20"
      },
      "react": {
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "babel-plugin-react-compiler": "1.0.0"
      },
      "tailwind": {
        "@tailwindcss/vite": "4.2.4",
        "class-variance-authority": "0.7.1",
        "clsx": "2.1.1",
        "tailwind-merge": "3.5.0",
        "tailwindcss": "4.2.4",
        "tw-animate-css": "1.4.0"
      },
      "trpc": {
        "@tanstack/react-query": "5.99.2",
        "@trpc/client": "11.16.0",
        "@trpc/server": "11.16.0",
        "@trpc/tanstack-react-query": "11.16.0"
      },
      "vite": {
        "@tanstack/react-router": "1.168.23",
        "@tanstack/react-router-ssr-query": "1.166.11",
        "@tanstack/react-start": "1.167.42",
        "@tanstack/router-plugin": "1.167.22",
        "@vitejs/plugin-react": "6.0.1",
        "@types/babel__core": "7.20.5",
        "vite": "8.0.9",
        "@rolldown/plugin-babel": "0.2.3",
        "nitro": "3.0.260415-beta"
      }
    }
  },
  "type": "module",
  "scripts": {
    "build": "bun run --filter '*' build",
    "clean": "git clean -xdfq 'node_modules/*' '**/node_modules/*' '**/dist/*'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "bunx --no-install --bun oxlint",
    "lint:fix": "bunx --no-install --bun oxlint --fix",
    "check": " bunx --no-install --bun oxlint && bunx --no-install --bun oxfmt --check",
    "fix": "bunx --no-install --bun oxlint --fix && bunx --no-install --bun oxfmt",
    "compose": "docker compose -f docker-compose.yaml -f docker-compose.dev.yaml up --build -d",
    "deps": "bun update --interactive --recursive"
  },
  "devDependencies": {
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.21.1"
  },
  "packageManager": "bun@1.3.11"
}
