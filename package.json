{
  "name": "reactlith-template",
  "private": true,
  "scripts": {
    "build": "pnpm run --filter '*' build",
    "clean": "git clean -xdfq 'node_modules/*' '**/node_modules/*' '**/dist/*'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check": "oxlint && oxfmt --check",
    "fix": "oxlint --fix && oxfmt",
    "compose": "docker compose -f docker-compose.yaml -f docker-compose.dev.yaml up --build -d",
    "deps": "pnpm update --interactive --recursive"
  },
  "devDependencies": {
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.18.1",
    "tsdown": "^0.21.8"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.6.0"
    }
  },
  "packageManager": "pnpm@11.0.0-rc.0"
}
